#!/usr/bin/env bash
# Blocks a commit if testing/scripts/check-consistency.sh fails. Not optional, not "remember to
# run it": mechanical checks that don't need judgment shouldn't depend on anyone remembering.
# See docs/deterministic-by-design.md.
#
# One-time setup per clone: git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
"$REPO_ROOT/testing/scripts/check-consistency.sh"
